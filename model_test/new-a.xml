<mujoco>
    <compiler angle="radian" meshdir="meshes" autolimits="true" />
    <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast" density="1.225" viscosity="1.8e-5" />
    <asset>
        <mesh name="tetrahedron" vertex="0 0 0 1 0 0 0 1 0 0 0 1" />
        <texture type="skybox" builtin="gradient" rgb1=".1 .1 .1" rgb2=".9 .9 .9" width="512" height="512"/>
        <texture name="plane" type="2d" builtin="checker" rgb1=".1 .1 .1" rgb2=".9 .9 .9"
            width="512" height="512" mark="cross" markrgb=".8 .8 .8" />
        <material name="plane" reflectance="0.3" texture="plane" texrepeat="1 1" texuniform="true" />
    </asset>

    <default>
         <joint damping="0.01"/>
    </default>
    
    <worldbody>
        <geom type="plane" material="plane" pos="0 0 0" size="0 0 .25"/>
        <light directional="true" dir="0 0 -1" diffuse="1 1 1" specular=".5 .5 .5"/>
        
        
        <body>
            <!-- <freejoint/> -->
            <geom type="sphere" size="0.001" mass="0.001" rgba="0 0 0 0"/>
            <body name="l1" pos="0 0 .8">
                <geom type="box" size=".005" fromto="0 0 0 0.098 0 0" rgba="0 1 0 .8" pos="0 0 0"/>
                <joint type="hinge" name="joint_l1" pos="0 0 0" axis="0 1 0"/>
                <site type="sphere" name="l1" size=".005" pos="0 0 0" rgba="1 0 0 1"/>
                
                <body name="l2" pos="0.098 0.012 0">
                    <joint type="hinge" name="joint_l2" pos="0 0 0" axis="0 1 0"/>
                    <geom type="box" size="0.005" fromto="0 0 0 -0.098 0 -0.06573" rgba="1 1 1 .8" />

                    <body name="l3" pos="-0.098 -0.012 -0.06573">
                    <joint type="hinge" name="joint_l3" pos="0 0 0" axis="0 1 0"/>
                    <geom type="box" size="0.005" fromto="0 0 0 -0.15115 0 0.10138" rgba="1 1 1 .8" />
                    <site type="sphere" name="l3" size=".005" pos="-0.098 0 0.06573" rgba="0 0 1 1"/>

                    <body name="l4" pos="-0.15115 0.012 0.10138">
                    <joint type="hinge" name="joint_l4" pos="0 0 0" axis="0 1 0"/>
                    <geom type="box" size="0.005" fromto="0 0 0 -0.117 0 0" rgba="0 1 0 .8" />

                    <body name="l5" pos="-0.117 -0.012 0">
                    <joint type="hinge" name="joint_l5" pos="0 0 0" axis="0 1 0"/>
                    <geom type="box" size="0.005" fromto="0 0 0 0.26742 0 -0.17936" rgba="0 1 0 .8" />
                    <site type="sphere" name="l5" size=".005" pos="0.05315 0 -0.03565" rgba="1 1 1 1"/>
                    
                    
                    </body>
                    </body>
                    </body>
                    </body>
            </body>
             
            <body name="l6" pos="0 0.012 0.8">
              <joint type="hinge" name="joint_l6" pos="0 0 0" axis="0 1 0"/>
              <!-- <joint type="hinge" name="joint_l6m" pos="-0.098 0 0" axis="0 1 0"/> -->
              <geom type="box" size="0.005" fromto="0 0 0 -0.215 0 0" rgba="0 1 0 .8" />
              <site type="sphere" name="l6r" size=".005" pos="0 0 0" rgba="1 1 1 1"/>
              <site type="sphere" name="l6m" size=".005" pos="-0.098 0 0" rgba="0 0 0 1"/>
              <site type="sphere" name="l6l" size=".005" pos="-0.215 0 0" rgba="0 0 0 1"/>
            </body>
            
        </body>
         

    </worldbody>

    <equality>
        <!-- <connect site1="l1" site2="l4"/> -->
         <!-- <connect site1="l1" site2="l6r"/> -->
         <connect site1="l3" site2="l6m"/>
         <connect site1="l5" site2="l6l"/>
    </equality>

</mujoco>